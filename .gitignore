# ============================================================
# Objectif.AI — .gitignore
# IMPORTANT: These files may contain your API key, system
# information, or large binary model files. Never commit them.
# ============================================================

# User configuration — contains API key and personal settings
config.yaml

# Log files — may contain system info (CPU/GPU names, paths)
logs/
*.log

# Downloaded model files — large binaries, not part of source
models/
*.pt
*.pth
*.onnx
*.engine
*.trt

# Plate image storage — contains user data (plate crops and full images)
# from ALPR. Never commit. Delete this folder to reset plate history.
plates/

# Legacy ONNX exports generated by the app
*.legacy.onnx

# Auto-generated by setup-service.bat — contains machine-specific python.exe path
start-silent.vbs

# Dependency install flag
.deps_installed

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Virtual environments
venv/
.venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# IDE files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp

# PyTorch hub cache (if redirected here)
hub/

# Test artifacts
.pytest_cache/
htmlcov/
.coverage
